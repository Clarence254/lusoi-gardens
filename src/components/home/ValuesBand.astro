---
const values = [
  {
    icon: 'flaticon-spa',
    title: 'Rest & Recharge',
    description: 'Peaceful spaces designed for total relaxation.',
  },
  {
    icon: 'ion-ios-cloud-outline',
    title: 'Iconic Views',
    description: 'Breathtaking views of Mount Kenya & beyond.',
  },
  {
    icon: 'ion-ios-people',
    title: 'Meaningful Connection',
    description: 'Quality time with loved ones in nature.',
  },
  {
    icon: 'flaticon-serving-dish',
    title: 'Nourish & Inspire',
    description: 'Farm-to-table dining made with care.',
  },
];
---

<section class="lusoi-values-band">
  <div class="lusoi-values-inner">
    <div class="row">
      {values.map((item) => (
        <div class="col-md-6 col-lg-3">
          <div class="lusoi-value-item ftco-animate">
            <div class="icon-wrap">
              <span class={item.icon}></span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
