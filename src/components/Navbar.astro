---
interface Props {
  activePage?: string;
}

const { activePage = '' } = Astro.props;

const navItems = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'Stay', href: '/cabins', key: 'cabins' },
  { label: 'Experiences', href: '/leisure-activities', key: 'experiences' },
  { label: 'Dining', href: '/dining', key: 'dining' },
  { label: 'Meetings', href: '/meetings-events', key: 'meeting-events' },
  { label: 'About', href: '/about', key: 'about' },
  { label: 'Contact', href: '/contact', key: 'contact' },
];
---

<nav class="navbar navbar-expand-lg navbar-dark ftco_navbar ftco-navbar-light lusoi-nav" id="ftco-navbar">
  <div class="container">
    <a class="navbar-brand" href="/">
      <img src="/images/lusoi-gardens-logo.png" alt="Lusoi Gardens" width="120" height="88">
    </a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#ftco-nav" aria-controls="ftco-nav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="oi oi-menu"></span> Menu
    </button>

    <div class="collapse navbar-collapse" id="ftco-nav">
      <ul class="navbar-nav mx-auto">
        {navItems.map((item) => (
          <li class={`nav-item ${activePage === item.key ? 'active' : ''}`}>
            <a href={item.href} class="nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
      <ul class="navbar-nav">
        <li class="nav-item cta">
          <a href="/contact" class="nav-link">Book your retreat</a>
        </li>
      </ul>
    </div>
    </div>
</nav>
