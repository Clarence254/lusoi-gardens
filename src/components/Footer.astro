---
const mapUrl = 'https://maps.google.com/?q=Nyeri,+Kenya';
---

<footer class="lusoi-footer">
  <div class="container">
    <div class="footer-row">
      <div class="footer-location">
        Nyeri, Kenya
        <span class="footer-separator" aria-hidden="true">|</span>
        <a href={mapUrl} target="_blank" rel="noopener noreferrer">View on Map</a>
      </div>
      <ul class="footer-social">
        <li>
          <a href="https://web.facebook.com/LusoiGardensResort" class="footer-social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <span class="icon-facebook"></span>
          </a>
        </li>
        <li>
          <a href="https://www.instagram.com/lusoigardensresort/" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <span class="icon-instagram"></span>
          </a>
        </li>
        <li>
          <a href="mailto:reservations@lusoigardens.com" class="footer-social-link" aria-label="Email">
            <span class="icon-envelope"></span>
          </a>
        </li>
      </ul>
      <div class="footer-contact">
        <a href="tel:+254797590865">+254 797 590 865</a>
        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="mailto:reservations@lusoigardens.com">reservations@lusoigardens.com</a>
      </div>
    </div>
  </div>
</footer>

<!-- loader -->
<div id="ftco-loader" class="show fullscreen"><svg class="circular" width="48px" height="48px"><circle class="path-bg" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke="#eeeeee"/><circle class="path" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke-miterlimit="10" stroke="#3b4d3a"/></svg></div>
