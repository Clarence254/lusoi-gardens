---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout 
  title="Leisure Activities & Outdoor Fun at Lusoi Gardens | Mount Kenya"
  activePage="experiences"
  description="Discover exciting leisure activities at Lusoi Gardens. Enjoy nature walks, kids park, mountain biking, evening bonfires, and more outdoor adventures for all ages near Mount Kenya."
  keywords="leisure activities Lusoi Gardens, outdoor activities Kenya, nature walks Mount Kenya, kids park Nanyuki, mountain biking Kenya, family activities, adventure activities Kenya, outdoor fun"
  ogImage="/images/kids-park.jpeg"

  enableGsap={true}
  gsapPage="marketing"
>
  <PageHero title="Leisure Activities" backgroundImage="/images/landing-3.jpg" />

  <PageIntro
    title="Experiences in Nature"
    lead="At Lusoi Gardens, we offer a diverse range of leisure activities designed to connect you with nature, create lasting memories, and provide moments of adventure and relaxation. Whether you're seeking outdoor exploration, family fun, or peaceful moments by the fire, our carefully curated experiences blend seamlessly with the natural beauty of Mount Kenya's foothills."
  />

  <!-- Tile Style Section -->
  <section class="lusoi-tiles-section ftco-no-pt ftco-no-pb">
    <div class="container-fluid px-0">
      <!-- Nature Walks & Hiking -->
      <div class="row no-gutters lusoi-tile-row">
        <div class="col-md-6 lusoi-tile-panel lusoi-tile-panel--dark">
          <div class="tile-content">
            <h2 class="mb-3">Nature Walks & Hiking</h2>
            <p class="lusoi-tile-eyebrow mb-4">EXPLORE THE TRAILS</p>
            <p>Guided nature walks along River Nairobi and through Ngare Ndare Forest. Discover waterfalls, canopy walkways, and diverse wildlife. Perfect for bird watching and photography with designated photo stops along the trails.</p>
          </div>
        </div>
        <div class="col-md-6 lusoi-tile-img lusoi-tile-img--nature-walk" aria-hidden="true"></div>
      </div>

      <!-- Restaurant -->
      <div class="row no-gutters lusoi-tile-row lusoi-tile-row--image-left">
        <div class="col-md-6 lusoi-tile-img lusoi-tile-img--restaurant" aria-hidden="true"></div>
        <div class="col-md-6 lusoi-tile-panel lusoi-tile-panel--light">
          <div class="tile-content">
            <h2 class="mb-3">Restaurant</h2>
            <p class="lusoi-tile-eyebrow mb-4">FRESH LOCAL CUISINE</p>
            <p>Savor a delicious meal made with ingredients harvested directly from our on-site farm and local producers. Our restaurant offers a seasonal menu that highlights the region's finest flavors, served in a warm and inviting atmosphere.</p>
          </div>
        </div>
      </div>

      <!-- Lush Gardens -->
      <div class="row no-gutters lusoi-tile-row">
        <div class="col-md-6 lusoi-tile-panel lusoi-tile-panel--dark">
          <div class="tile-content">
            <h2 class="mb-3">Lush Gardens</h2>
            <p class="lusoi-tile-eyebrow mb-4">PEACEFUL RETREAT</p>
            <p>Stroll through beautifully curated gardens featuring native plants, flowering pathways, and quiet seating areas. A perfect setting for relaxation, photography, or simply enjoying the peaceful surroundings.</p>
          </div>
        </div>
        <div class="col-md-6 lusoi-tile-img lusoi-tile-img--gardens" aria-hidden="true"></div>
      </div>

      <!-- Relaxation & Fireside -->
      <div class="row no-gutters lusoi-tile-row lusoi-tile-row--image-left">
        <div class="col-md-6 lusoi-tile-img lusoi-tile-img--bonfire" aria-hidden="true"></div>
        <div class="col-md-6 lusoi-tile-panel lusoi-tile-panel--light">
          <div class="tile-content">
            <h2 class="mb-3">Relaxation & Fireside</h2>
            <p class="lusoi-tile-eyebrow mb-4">UNWIND & RECONNECT</p>
            <p>Garden lounges, outdoor café, and cozy corners with hammocks and reading nooks. Fireside evenings with blankets, herbal tea, and storytelling under the stars. Perfect for group events and team-building. Available on request.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PageCta
    title="Explore Our Experiences"
    description="Plan your visit and discover everything Lusoi Gardens has to offer."
    buttonText="Plan Your Visit"
    buttonHref="/about"
  />
</BaseLayout>

