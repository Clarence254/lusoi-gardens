---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ValuesBand from '../components/home/ValuesBand.astro';
import FeatureCards from '../components/home/FeatureCards.astro';
import GatherSection from '../components/home/GatherSection.astro';
import DiningSection from '../components/home/DiningSection.astro';
import CtaBar from '../components/home/CtaBar.astro';
import ValuesRow from '../components/home/ValuesRow.astro';
---

<BaseLayout
  title="Lusoi Gardens | Rediscover What Matters"
  activePage="home"
  description="A luxury nature retreat in the heart of Mount Kenya & the Aberdare Ranges. Book your retreat at Lusoi Gardens."
  keywords="Lusoi Gardens, Mount Kenya resort, nature retreat Kenya, luxury cabins, farm-to-table dining, meetings events Kenya"
  ogImage="/images/landing-3.jpg"
  enableGsap={true}
  gsapPage="home"
>
  <Hero />
  <ValuesBand />
  <FeatureCards />
  <GatherSection />
  <DiningSection />
  <CtaBar />
  <ValuesRow />
</BaseLayout>
