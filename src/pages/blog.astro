---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout 
  title="Blog - Latest News & Stories from Lusoi Gardens | Mount Kenya Resort"
  activePage="blog"
  description="Read our latest blog posts about Lusoi Gardens, Mount Kenya adventures, travel tips, and stories from our nature retreat. Stay updated with news and insights from Kenya's beautiful countryside."
  keywords="Lusoi Gardens blog, Mount Kenya travel blog, Kenya resort news, nature retreat stories, travel tips Kenya, Mount Kenya adventures, resort blog"
  ogImage="/images/image_1.jpg"

  enableGsap={true}
  gsapPage="marketing"
>
