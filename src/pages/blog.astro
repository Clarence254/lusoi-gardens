  <PageIntro eyebrow="Read Blog" title="Recent Blog" narrow />

	<section class="ftco-section lusoi-blog-section">
    <div class="container">
      <div class="row d-flex">
        <div class="col-md-4 d-flex ftco-animate">
          <div class="blog-entry align-self-stretch">
            <a href="/blog-single" class="block-20" style={{ backgroundImage: "url('/images/image_1.jpg')" }}>
            </a>
            <div class="text mt-3 text-center">
            	<div class="meta mb-2">
                <div><a href="#">July 03, 2019</a></div>
                <div><a href="#">Admin</a></div>
                <div><a href="#" class="meta-chat"><span class="icon-chat"></span> 3</a></div>
              </div>
              <h3 class="heading"><a href="#">Even the all-powerful Pointing has no control about the blind texts</a></h3>
