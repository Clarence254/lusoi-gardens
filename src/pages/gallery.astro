---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout
  title="Gallery - Lusoi Gardens | Photos of Our Mount Kenya Retreat"
  activePage="gallery"
  description="Browse photos of Lusoi Gardens near Mount Kenya. Explore our cabins, gardens, dining, conference facilities, and the beautiful natural surroundings."
  keywords="Lusoi Gardens photos, resort gallery, Mount Kenya resort images, Nyeri resort photos, Kenya retreat gallery"
  ogImage="/images/landscape-1.jpg"

  enableGsap={true}
  gsapPage="marketing"
>
  <PageHero title="Gallery" backgroundImage="/images/landing-3.jpg" />

  <PageIntro
    eyebrow="A Glimpse of Lusoi"
    title="Moments Captured at the Resort"
    lead="From lush gardens and cozy cabins to sweeping highland views, here is a glimpse of what awaits you at Lusoi Gardens."
    narrow
  />

  <!-- Gallery Grid -->
  <section class="ftco-section ftco-no-pt lusoi-gallery-section">
    <div class="container">
      <div class="row">
        <!-- Row 1 -->
        <div class="col-md-4 ftco-animate">
          <a href="/images/exterior-1.jpg" class="gallery-item image-popup">
            <div class="gallery-img" style={{ backgroundImage: "url('/images/exterior-1.jpg')" }}></div>
            <div class="gallery-overlay">
              <span class="ion-ios-expand"></span>
            </div>
          </a>
        </div>
        <div class="col-md-4 ftco-animate">
