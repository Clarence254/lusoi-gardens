---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout
  title="Dining at Lusoi Gardens - Farm-to-Table Restaurant Near Mount Kenya"
  activePage="dining"
  description="Enjoy farm-to-table dining at Lusoi Gardens's hilltop restaurant with views of Mount Kenya and the Aberdare Ranges. Buffet and a la carte options for breakfast, lunch, and dinner."
  keywords="Lusoi Gardens restaurant, dining Mount Kenya, farm to table Kenya, restaurant Nyeri, resort dining, breakfast lunch dinner Kenya"
  ogImage="/images/restaurant-1.jpg"
  enableGsap={true}
  gsapPage="marketing"
>
  <PageHero title="Dining" backgroundImage="/images/exterior-1.jpg" />

  <PageIntro
    eyebrow="The Restaurant"
    title="Dining at the Top"
    lead="Perched at the highest point of the resort, our restaurant offers more than just a meal. On a clear day, guests are treated to sweeping views of Mount Kenya and the Aberdare Ranges, a backdrop that turns every dining occasion into something truly special."
    narrow
  />

  <!-- Full-width image -->
  <section class="ftco-no-pt ftco-no-pb">
    <div class="container-fluid px-0">
      <div class="dining-hero-img" style={{ backgroundImage: "url('/images/restaurant-1.jpg')" }}></div>
    </div>
  </section>

  <!-- Dining details - Image Right -->
  <section class="ftco-section ftco-no-pb">
    <div class="container-fluid px-0">
      <div class="row no-gutters align-items-stretch">
        <div class="col-md-6 d-flex align-items-center ftco-animate">
          <div class="dining-detail-text">
            <h3>Savour the Flavour</h3>
            <p>The restaurant comfortably accommodates up to 30 guests and offers both buffet and a la carte dining options. Whether you are starting the day with a hearty breakfast, enjoying a leisurely lunch, or settling in for a relaxed dinner, every meal is prepared with care using fresh, locally sourced ingredients.</p>
            <p>Only non-alcoholic drinks are served, keeping the atmosphere family-friendly and serene.</p>
          </div>
        </div>
        <div class="col-md-6 ftco-animate">
          <div class="dining-detail-img" style={{ backgroundImage: "url('/images/restaurant-4.jpg')" }}></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Farm to table - Image Left -->
  <section class="ftco-section">
    <div class="container-fluid px-0">
      <div class="row no-gutters align-items-stretch">
        <div class="col-md-6 ftco-animate">
          <div class="dining-detail-img" style={{ backgroundImage: "url('/images/farm-1.jpg')" }}></div>
        </div>
        <div class="col-md-6 d-flex align-items-center ftco-animate">
          <div class="dining-detail-text">
            <h3>Farm to Table</h3>
            <p>At Lusoi Gardens, every meal is a celebration of flavour and freshness, thanks to the resort's well-tended garden nourished by rich, loamy soil. Vibrant vegetables, aromatic herbs, and seasonal produce are harvested directly from the garden to create wholesome, delicious dishes.</p>
            <p>This commitment to sustainability and natural ingredients ensures that every bite is packed with authentic taste and nutritional value.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fire Pit Experience - Image Right -->
  <section class="ftco-section ftco-no-pb">
    <div class="container-fluid px-0">
      <div class="row no-gutters align-items-stretch">
        <div class="col-md-6 d-flex align-items-center ftco-animate">
          <div class="dining-detail-text">
            <h3>The Fire Pit Experience</h3>
            <p>Create wonderful memories with friends and family, amid the warm, inviting crackling of the lit bonfire, while indulging in our Fire Pit Experience menu which includes: One whole roasted goat, with various accompaniments.</p>
            <!-- <p class="fire-pit-price">KES 25,000</p> -->
            <a href="/contact" class="btn fire-pit-btn mt-3">Book This Experience</a>
          </div>
        </div>
        <div class="col-md-6 ftco-animate">
          <div class="dining-detail-img" style={{ backgroundImage: "url('/images/fire-pit.jpg')" }}></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Meal times -->
  <section class="ftco-section dining-times-section">
    <div class="container">
      <div class="row justify-content-center mb-5">
        <div class="col-md-8 text-center ftco-animate">
          <span class="subheading">Hours</span>
          <h2 class="dining-heading mb-4">Meal Times</h2>
        </div>
      </div>
      <div class="row justify-content-center">
        <div class="col-md-4 ftco-animate">
          <div class="dining-time-card text-center">
            <div class="dining-time-icon">
              <span class="flaticon-serving-dish"></span>
            </div>
            <h4>Breakfast</h4>
            <p class="dining-time">6:30 am — 10:00 am</p>
          </div>
        </div>
        <div class="col-md-4 ftco-animate">
          <div class="dining-time-card text-center">
            <div class="dining-time-icon">
              <span class="flaticon-serving-dish"></span>
            </div>
            <h4>Lunch</h4>
            <p class="dining-time">12:30 pm — 3:00 pm</p>
          </div>
        </div>
        <div class="col-md-4 ftco-animate">
          <div class="dining-time-card text-center">
            <div class="dining-time-icon">
              <span class="flaticon-serving-dish"></span>
            </div>
            <h4>Dinner</h4>
            <p class="dining-time">6:00 pm — 9:00 pm</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PageCta
    title="Join Us for a Meal"
    description="Whether you are a guest at the resort or visiting for the day, we welcome you to experience dining at the top."
    buttonText="Make a Reservation"
  />
</BaseLayout>

