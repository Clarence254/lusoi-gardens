---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout 
  title="Nearby Attractions - Explore Kenya's Natural Wonders from Lusoi Gardens"
  activePage="nearby-attractions"
  description="Discover stunning attractions near Lusoi Gardens including Mount Kenya National Park, Equator Marker, Ol Pejeta Conservancy, and more. We organize guided tours and transport for easy exploration."
  keywords="nearby attractions Lusoi Gardens, Mount Kenya National Park, Equator Marker Nanyuki, Ol Pejeta Conservancy, Samburu National Reserve, Meru National Park, Kenya attractions, guided tours Mount Kenya"
  ogImage="/images/mtkenya-park.jpg"

  enableGsap={true}
  gsapPage="marketing"
>
  <PageHero title="Nearby Attractions" backgroundImage="/images/landing-3.jpg" />

  <PageIntro
    eyebrow="Explore Kenya"
    title="Discover the Beauty Around Us"
    lead="We're surrounded by some of Kenya's most stunning natural and cultural attractions. Our team can organize guided tours and comfortable transport to these serene destinations — so you can explore with ease."
    narrow
  />

  <section class="ftco-section lusoi-nearby-section">
	<div class="container">
		<div class="row">
	  <div class="col-md-6">
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img order-md-last" style={{ backgroundImage: "url('/images/equator.jpg')" }}></div>
			  <div class="desc pr-3 text-md-right">
				  <div class="d-md-flex text align-items-center">
					  <h3 class="order-md-last heading-left"><span>Equator Marker</span></h3>
					  <span class="price price-left">20 km</span>
				  </div>
				  <div class="d-block">
					  <p>Stand at the center of the world where the northern and southern hemispheres meet</p>
				  </div>
			  </div>
		  </div>
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img order-md-last" style={{ backgroundImage: "url('/images/mtkenya-park.jpg')" }}></div>
			  <div class="desc pr-3 text-md-right">
				  <div class="d-md-flex text align-items-center">
					  <h3 class="order-md-last heading-left"><span>Mount Kenya National Park</span></h3>
					  <span class="price price-left">19 km</span>
				  </div>
				  <div class="d-block">
					  <p>Experience Africa's second highest peak and its diverse wildlife</p>
				  </div>
			  </div>
		  </div>
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img order-md-last" style={{ backgroundImage: "url('/images/mtkenya-orphanage.jpeg')" }}></div>
			  <div class="desc pr-3 text-md-right">
				  <div class="d-md-flex text align-items-center">
					  <h3 class="order-md-last heading-left"><span>Mount Kenya Animal Orphanage</span></h3>
					  <span class="price price-left">30 km</span>
				  </div>
				  <div class="d-block">
					  <p>Encounter rescued wildlife in a sanctuary dedicated to conservation</p>
				  </div>
			  </div>
		  </div>
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img order-md-last" style={{ backgroundImage: "url('https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800&h=600&fit=crop')" }}></div>
			  <div class="desc pr-3 text-md-right">
				  <div class="d-md-flex text align-items-center">
					  <h3 class="order-md-last heading-left"><span>Ol Pejeta Conservancy</span></h3>
					  <span class="price price-left">26 km</span>
				  </div>
				  <div class="d-block">
					  <p>Witness the Big Five and rare northern white rhinos in their natural habitat</p>
				  </div>
			  </div>
		  </div>
	  </div>

	  <div class="col-md-6">
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img" style={{ backgroundImage: "url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=800&h=600&fit=crop')" }}></div>
			  <div class="desc pl-3">
				  <div class="d-md-flex text align-items-center">
					  <h3><span>Ngare Ndare Forest Park</span></h3>
					  <span class="price">59 km</span>
				  </div>
				  <div class="d-block">
					  <p>Discover pristine forests, waterfalls, and canopy walkways</p>
				  </div>
			  </div>
		  </div>
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img" style={{ backgroundImage: "url('/images/BPHOUSE.jpg')" }}></div>
			  <div class="desc pl-3">
				  <div class="d-md-flex text align-items-center">
					  <h3><span>Baden-Powell's House, Nyeri</span></h3>
					  <span class="price">38 km</span>
				  </div>
				  <div class="d-block">
					  <p>Visit the historic home of the founder of the Scouting movement</p>
				  </div>
			  </div>
		  </div>
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img" style={{ backgroundImage: "url('/images/samburu-reserve.jpeg')" }}></div>
			  <div class="desc pl-3">
				  <div class="d-md-flex text align-items-center">
					  <h3><span>Samburu National Reserve</span></h3>
					  <span class="price">160 km</span>
				  </div>
				  <div class="d-block">
					  <p>Explore unique wildlife species found only in northern Kenya</p>
				  </div>
			  </div>
		  </div>
		  <div class="pricing-entry d-flex ftco-animate">
			  <div class="img" style={{ backgroundImage: "url('/images/meru-national-park.jpg')" }}></div>
			  <div class="desc pl-3">
				  <div class="d-md-flex text align-items-center">
					  <h3><span>Meru National Park</span></h3>
					  <span class="price">160 km</span>
				  </div>
				  <div class="d-block">
					  <p>Experience the wild beauty that inspired Joy Adamson's "Born Free"</p>
				  </div>
			  </div>
		  </div>
	  </div>
  </div>
	</div>
</section>
  <PageCta
    title="Plan Your Adventure"
    description="Ask our team to arrange guided tours and transport to nearby attractions."
    buttonText="Contact Us"
  />
</BaseLayout>

