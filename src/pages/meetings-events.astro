---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout
  title="Meetings & Events at Lusoi Gardens - Conference Venue Near Mount Kenya"
  activePage="meeting-events"
  description="Host your next meeting, conference, or special event at Lusoi Gardens. Versatile meeting room for up to 25 guests, scenic outdoor event spaces, and tailored conference packages near Mount Kenya."
  keywords="Lusoi Gardens meetings, conference venue Nyeri, event space Mount Kenya, corporate retreat Kenya, workshop venue, team building Kenya, wedding venue Nyeri"
  ogImage="/images/conference-room.jpg"
  enableGsap={true}
  gsapPage="marketing"
>
  <PageHero title="Meetings & Events" backgroundImage="/images/landing-3.jpg" />

  <PageIntro
    eyebrow="Gather & Connect"
    title="The Perfect Setting for Every Occasion"
    lead="Whether you are planning a corporate retreat, an intimate workshop, or a special celebration, Lusoi Gardens offers versatile spaces set against the stunning backdrop of Mount Kenya and the Aberdare Ranges. Let the tranquility of nature inspire your next gathering."
    narrow
  />

  <!-- Full-width image -->
  {/* <section class="ftco-no-pt ftco-no-pb">
    <div class="container-fluid px-0">
      <div class="me-hero-img" style={{ backgroundImage: "url('/images/conference-room.jpg')" }}></div>
    </div>
  </section> */}

  <!-- Meeting Room - Image Right -->
  <section class="ftco-section ftco-no-pb">
    <div class="container-fluid px-0">
      <div class="row no-gutters align-items-stretch">
        <div class="col-md-6 d-flex align-items-center ftco-animate">
          <div class="me-detail-text">
            <h3>The Meeting Room</h3>
            <p>Our dedicated meeting room comfortably accommodates up to 25 guests in a calm, focused setting. Fully equipped with Wi-Fi connectivity, the space is ideal for corporate meetings, strategic workshops, training sessions, and intimate conferences.</p>
            <p>The room features flexible seating arrangements to suit your format. Whether boardroom-style discussions, classroom setups, or collaborative U-shape configurations.</p>
          </div>
        </div>
        <div class="col-md-6 ftco-animate">
          <div class="me-detail-img" style={{ backgroundImage: "url('/images/meeting-room.jpg')" }}></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Event Space - Image Left -->
  <section class="ftco-section">
    <div class="container-fluid px-0">
      <div class="row no-gutters align-items-stretch">
        <div class="col-md-6 ftco-animate">
          <div class="me-detail-img" style={{ backgroundImage: "url('/images/outdoor-space.jpg')" }}></div>
        </div>
        <div class="col-md-6 d-flex align-items-center ftco-animate">
          <div class="me-detail-text">
            <h3>Outdoor Event Space</h3>
            <p>For larger gatherings, our beautifully landscaped gardens provide a breathtaking open-air venue. From team-building activities and family celebrations to intimate weddings set against panoramic highland views, the outdoor space brings a unique charm to every event.</p>
            <p>Let nature set the scene while our team takes care of the details, ensuring a seamless and memorable experience for you and your guests.</p>
            <p>Ample parking is available on-site for all guests and event attendees.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* <!-- Conference Packages -->
  <section class="ftco-section me-packages-section">
    <div class="container">
      <div class="row justify-content-center mb-5">
        <div class="col-md-8 text-center ftco-animate">
          <span class="subheading">Packages</span>
          <h2 class="me-heading mb-4">Conference Packages</h2>
        </div>
      </div>
      <div class="row justify-content-center">
        <div class="col-md-5 ftco-animate">
          <div class="me-package-card text-center">
            <div class="me-package-icon">
              <span class="flaticon-serving-dish"></span>
            </div>
            <h4>Half Board</h4>
            <p>Includes the meeting room, morning tea, lunch, and afternoon tea — perfect for focused day sessions that keep your team energised and productive.</p>
          </div>
        </div>
        <div class="col-md-5 ftco-animate">
          <div class="me-package-card text-center">
            <div class="me-package-icon">
              <span class="flaticon-serving-dish"></span>
            </div>
            <h4>Full Board</h4>
            <p>A comprehensive package covering accommodation, all meals, and the meeting room — ideal for multi-day retreats, conferences, and team-building getaways.</p>
          </div>
        </div>
      </div>
      <div class="row justify-content-center mt-4">
        <div class="col-md-8 text-center ftco-animate">
          <p class="me-parking-note">Ample parking is available on-site for all guests and event attendees.</p>
        </div>
      </div>
    </div>
  </section> */}

  <PageCta
    title="Ready to Plan Your Event?"
    description="Get in touch with our team to discuss your requirements and receive a tailored package for your meeting or event."
    buttonText="Plan Your Meeting / Event"
  />
</BaseLayout>

