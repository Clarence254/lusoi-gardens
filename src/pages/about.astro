---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageIntro from '../components/PageIntro.astro';
import PageCta from '../components/PageCta.astro';
---

<BaseLayout
  title="Plan Your Visit - Lusoi Gardens | Getting Here, Weather & What to Pack"
  activePage="about"
  description="Plan your visit to Lusoi Gardens. Find directions from Nairobi, weather and climate information, what to pack, and the best time to visit our Mount Kenya retreat."
  keywords="Lusoi Gardens directions, how to get to Lusoi Gardens, Lusoi Gardens weather, what to pack Mount Kenya, best time to visit Nanyuki, plan trip Lusoi Gardens"
  ogImage="/images/exterior-1.jpg"
  enableGsap={true}
  gsapPage="marketing"
>
  <PageHero title="Plan Your Visit" backgroundImage="/images/landing-3.jpg" />

	<PageIntro
		title="Plan Your Visit"
		lead="Ready to visit Lusoi Gardens? Whether you are planning a weekend family getaway, a mid-week corporate retreat, or a quiet escape with friends, this guide covers everything you need to know before you arrive, from how to get here and what the weather is like, to what to pack and when to visit."
	/>

	<!-- Visitor's Guide - Alternating Blocks -->
	<section class="why-stay-section">
		<div class="why-stay-header">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-md-7 heading-section text-center ftco-animate">
						<h2 class="mb-4">Visitor's Guide</h2>
					</div>
				</div>
			</div>
		</div>

		<!-- Block 1: Getting Here — Image Left, Text Right -->
		<div class="why-stay-block">
			<div class="container-fluid px-0">
				<div class="row no-gutters align-items-stretch">
					<div class="col-md-6 ftco-animate">
						<div class="why-stay-img" style={{ backgroundImage: "url('/images/exterior-5.jpg')" }}></div>
					</div>
					<div class="col-md-6 d-flex align-items-center ftco-animate">
						<div class="why-stay-text">
							<h3>Getting Here</h3>
							<div style="font-family: 'Poppins', Arial, sans-serif; color: #666; font-size: 15px; line-height: 2;">
								<p class="mb-2"><strong>Nairobi:</strong> Approximately 150 km (2.5–3 hours drive)</p>
								<p class="mb-2"><strong>Nanyuki Airstrip:</strong> Approximately 22 km (30–40 minutes drive)</p>
								<p class="mb-2"><strong>Nyeri Town:</strong> Approximately 25 km (30–40 minutes drive)</p>
								<p class="mb-2"><strong>Embu Town:</strong> Approximately 100 km (1.5–2 hours drive)</p>
								<p class="mb-3"><strong>Meru Town:</strong> Approximately 120 km (2–2.5 hours drive)</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Block 2: Weather & Climate — Text Left, Image Right -->
		<div class="why-stay-block">
			<div class="container-fluid px-0">
				<div class="row no-gutters align-items-stretch">
					<div class="col-md-6 order-md-2 ftco-animate">
						<div class="why-stay-img" style={{ backgroundImage: "url('/images/landing-1.jpg')" }}></div>
					</div>
					<div class="col-md-6 order-md-1 d-flex align-items-center ftco-animate">
						<div class="why-stay-text">
							<h3>Weather & Climate</h3>
							<p>The foothills of Mount Kenya enjoy a temperate climate with cool mornings and evenings. Daytime temperatures are generally pleasant, making it ideal for outdoor activities. The area experiences two rainy seasons: long rains (March–May) and short rains (October–December). The best clear-sky months are June through September and January through February, perfect for stunning views of Mount Kenya.</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Block 3: What to Pack — Image Left, Text Right -->
		<div class="why-stay-block">
			<div class="container-fluid px-0">
				<div class="row no-gutters align-items-stretch">
					<div class="col-md-6 ftco-animate">
						<div class="why-stay-img" style={{ backgroundImage: "url('/images/interior-1.jpg')" }}></div>
					</div>
					<div class="col-md-6 d-flex align-items-center ftco-animate">
						<div class="why-stay-text">
							<h3>What to Pack</h3>
							<ul class="pack-list">
								<li><strong>Layers:</strong> Warm clothing for cool mornings and evenings, lighter options for daytime</li>
								<li><strong>Walking shoes:</strong> Comfortable, sturdy footwear for nature trails and garden walks</li>
								<li><strong>Rain gear:</strong> A light waterproof jacket, especially during the rainy seasons</li>
								<li><strong>Sun protection:</strong> Sunscreen, sunglasses, and a hat for daytime activities</li>
								<li><strong>Binoculars:</strong> For birding — Lusoi Gardens is home to a wide variety of bird species</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<PageCta
		title="Ready to Experience Lusoi Gardens?"
		description="Start planning your perfect getaway in Kenya's highlands."
		buttonText="Make an Inquiry"
	/>
</BaseLayout>

